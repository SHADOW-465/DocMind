# Lucent ML — example environment for API reword mode (copy to ml/.env)
#
# Default behavior (no env needed) uses the local transformers model.
# To reword via hosted LLMs instead — NVIDIA NIM primary, Groq fallback — set:

LUCENT_REWORD_PROVIDER=api

# NVIDIA NIM (free tier): get a key at https://build.nvidia.com
NVIDIA_API_KEY=
# LUCENT_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# LUCENT_NIM_MODEL=meta/llama-3.1-8b-instruct

# Groq (fallback): get a key at https://console.groq.com/keys
GROQ_API_KEY=
# LUCENT_GROQ_BASE_URL=https://api.groq.com/openai/v1
# LUCENT_GROQ_MODEL=llama-3.1-8b-instant

# Optional
# LUCENT_API_TIMEOUT_S=30
# LUCENT_MAX_UPLOAD_MB=25

# CORS — origins allowed to call this backend. Default: http://localhost:3000.
# Set to your deployed frontend's URL so a hosted web app can reach this service
# (comma-separated for several, or "*" for open testing). Example:
# LUCENT_CORS_ORIGINS=https://your-app.vercel.app
# LUCENT_CORS_ORIGINS=*
